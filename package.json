{
  "name": "markdown-codeblock-fold-support",
  "displayName": "Markdown Code Block Fold Support",
  "description": "Adds folding support for structured content inside Markdown fenced code blocks across JSON, JS/TS, CSS, YAML, and HTML-like languages.",
  "version": "0.0.3",
  "publisher": "YiJie",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/NWYLZW/vscode-md-codeblock-fold-support.git"
  },
  "homepage": "https://github.com/NWYLZW/vscode-md-codeblock-fold-support#readme",
  "bugs": {
    "url": "https://github.com/NWYLZW/vscode-md-codeblock-fold-support/issues"
  },
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:markdown"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Markdown Code Block Fold Support",
      "properties": {
        "markdownCodeBlockFoldSupport.enabledLanguages": {
          "type": "array",
          "default": [
            "json",
            "jsonc",
            "javascript",
            "javascriptreact",
            "js",
            "jsx",
            "typescript",
            "typescriptreact",
            "ts",
            "tsx",
            "mjs",
            "cjs",
            "css",
            "scss",
            "less",
            "yaml",
            "yml",
            "html",
            "xml",
            "xhtml",
            "svg",
            "vue",
            "svelte"
          ],
          "description": "Embedded fenced code block languages in Markdown that should contribute extra folding ranges.",
          "items": {
            "type": "string"
          }
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package --allow-missing-repository",
    "package:release": "version=$(node -p \"require('./package.json').version\") && mkdir -p release-assets && vsce package --allow-missing-repository --out \"release-assets/markdown-codeblock-fold-support-${version}.vsix\"",
    "pretest": "npm run compile",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.15.30",
    "@types/vscode": "^1.110.0",
    "@vscode/vsce": "^3.7.1",
    "@vscode/test-electron": "^2.5.2",
    "mocha": "^10.8.2",
    "typescript": "5.9.3"
  }
}
